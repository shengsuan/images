TIMEZONE=Asia/Shanghai
SSH_USERNAME=codespace

# SSH password (REQUIRED - set a strong password)
# Generate a strong password: openssl rand -base64 32
SSH_PASSWORD=

# Timezone (default: Asia/Shanghai)
TIMEZONE=Asia/Shanghai

# SSH port exposed on host (default: 2222)
SSHD_PORT=2222

# Gateway ports setting (default: yes)
GATEWAY_PORTS=yes

SHENGSUANYUN_API_KEY=your_shengsuanyun_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=custom_openai_base_url_if_needed
ANTHROPIC_BASE_URL=custom_anthropic_base_url_if_needed
CODEX_DEFAULT_MODEL=your_default_codex_model_here
CLAUDE_CODE_DEFAULT_MODEL=your_default_claude_model_here
DEVPOD_IMAGE=vsc-universal:v0.1.0